#!/bin/sh
# Waybar status script for `td` (the todo-golang CLI).
# Outputs a single JSON line: {"text":..., "tooltip":..., "class":...}
# - text: icon + pending count
# - tooltip: full pending list
# - class: "pending" when there are open tasks, "empty" otherwise

# Resolve the datafile the same way `td` does, so we honor
# TODO_DATAFILE, $HOME/.todo.yaml, and --datafile consistently.
DATA=$(awk -F': *' '/^datafile:/ {print $2; exit}' "$HOME/.todo.yaml" 2>/dev/null)
DATA=${DATA:-$HOME/.tasks.json}

# Strip surrounding quotes the YAML parser might leave behind.
DATA=${DATA%\"}
DATA=${DATA#\"}

count_line=$(td list --count 2>/dev/null)
pending=$(printf '%s' "$count_line" | sed -n 's/.*"pending":\([0-9]*\).*/\1/p')
[ -z "$pending" ] && pending=0

# Nerd Font / FA6 "tasks" (clipboard-with-checks) + pending count.
text=$(printf '\uf0ae %s' "$pending")
class=empty
[ "$pending" -gt 0 ] && class=pending

tooltip=$(td list 2>/dev/null)
if [ -z "$tooltip" ]; then
    tooltip='No pending tasks'
else
    # JSON-escape: replace literal newlines with "\n" and escape quotes.
    tooltip=$(printf '%s' "$tooltip" \
        | sed ':a;N;$!ba;s/\n/\\n/g' \
        | sed 's/"/\\"/g')
fi

printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$text" "$tooltip" "$class"
